{
  "expo": {
    "name": "readFlow",
    "slug": "readflow",
    "version": "1.0.18",
    "orientation": "default",
    "userInterfaceStyle": "light",
    "scheme": "readflow",
    "primaryColor": "#D95D39",
    "backgroundColor": "#F4ECD6",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4ECD6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.urmiaworks.readflow",
      "buildNumber": "18",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      }
    },
    "android": {
      "package": "com.urmiaworks.readflow",
      "versionCode": 18,
      "permissions": [
        "INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "INTERNET",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F4ECD6"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-document-picker",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 220,
          "backgroundColor": "#F4ECD6",
          "resizeMode": "contain"
        }
      ],
      "expo-audio",
      "./plugins/withSherpaCodegenGradleFix"
    ],
    "extra": {
      "apiUrl": "https://readflow-backend-internal.onrender.com",
      "appKey": "8bdafe087ef5b82bdc6790a2b9d62d29",
      "supportEmail": "support@urmiaworks.com",
      "website": "https://urmiaworks.com",
      "privacyPolicy": "https://urmiaworks.com/readflow/privacy",
      "eas": {
        "projectId": "097b0b5a-db90-46b4-b434-60836687b429"
      }
    }
  }
}
