# Server
PORT=4000

# AI provider selection: "openai" (default). Later: "claude", "ollama".
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# TTS provider hint for the client (server does not do TTS in MVP).
# "device" = free on-device voice. "cloud" = future cloud TTS.
TTS_PROVIDER=device
